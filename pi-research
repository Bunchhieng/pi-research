# ---------------------------------------------------------------------------
# Animated bun progress bar
# ---------------------------------------------------------------------------

repeat_char() {
  local char="$1" count="$2" result="" i
  for ((i=0; i<count; i++)); do result+="$char"; done
  printf '%s' "$result"
}

# bun_progress <label> <pid...>  вҖ” animates until ALL given pids finish
bun_progress() {
  local label="$1"
  shift
  local pids=("$@")
  local width=32 i=0
  local frames=('(\(\  ' '(вҖўПүвҖў) ' '(/(\  ' '(вҖўПүвҖў) ')

  while true; do
    local running=0
    for pid in "${pids[@]}"; do
      kill -0 "$pid" 2>/dev/null && running=1 && break
    done
    [[ $running -eq 0 ]] && break
    local filled=$(( i % (width + 1) ))
    local bar
    bar="$(repeat_char 'в–Ҳ' "$filled")$(repeat_char 'в–‘' "$((width - filled))")"
    printf '\r  %-22s \033[38;5;214m[\033[0m%s\033[38;5;214m]\033[0m \033[38;5;172m%s\033[0m' \
      "$label" "$bar" "${frames[$((i % 4))]}"
    ((i++)) || true
    sleep 0.04
  done

  local bar
  bar="$(repeat_char 'в–Ҳ' "$width")"
  printf '\r  %-22s \033[38;5;214m[\033[0m%s\033[38;5;214m]\033[0m \033[32mвң“\033[0m\n' \
    "$label" "$bar"
}

# ---------------------------------------------------------------------------
# Shared: collect autoresearch/* worktrees into AR_PATHS / AR_BRANCHES
# ---------------------------------------------------------------------------

collect_ar_worktrees() {
  AR_PATHS=()
  AR_BRANCHES=()
  local cur_path="" cur_branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        if [[ -n "$cur_path" && "$cur_branch" == refs/heads/autoresearch/* ]]; then
          AR_PATHS+=("$cur_path"); AR_BRANCHES+=("${cur_branch#refs/heads/}")
        fi
        cur_path="${line#worktree }"; cur_branch=""
        ;;
      "branch "*) cur_branch="${line#branch }" ;;
    esac
  done < <(git -C "$REPO_ROOT" worktree list --porcelain)
  if [[ -n "$cur_path" && "$cur_branch" == refs/heads/autoresearch/* ]]; then
    AR_PATHS+=("$cur_path"); AR_BRANCHES+=("${cur_branch#refs/heads/}")
  fi
}

# ---------------------------------------------------------------------------
# Status command
# ---------------------------------------------------------------------------

cmd_status() {
  resolve_repo

  declare -a AR_PATHS=() AR_BRANCHES=()
  collect_ar_worktrees

  if [[ ${#AR_PATHS[@]} -eq 0 ]]; then
    echo ""
    echo -e "  ${DIM}No autoresearch worktrees found. Run pi-research to start one.${NC}"
    echo ""
    exit 0
  fi

  # Collect tmux state as plain text (bash 3.2: no associative arrays)
  local tmux_panes="" attached_sessions=""
  if command -v tmux &>/dev/null; then
    tmux_panes=$(tmux list-panes -a \
      -F "#{pane_current_path}\t#{session_name}" 2>/dev/null || true)
    attached_sessions=$(tmux list-sessions \
      -F "#{session_name} #{session_attached}" 2>/dev/null \
      | awk '$2==1{print $1}' || true)
  fi

  # Merged branches as plain text
  local merged_branches
  merged_branches=$(git -C "$REPO_ROOT" branch --merged "$BASE_BRANCH" \
    --list 'autoresearch/*' 2>/dev/null || true)

  echo ""
  echo -e "  ${BOLD}Research sessions${NC}  ${DIM}repo: ${REPO_NAME}  base: ${BASE_BRANCH}${NC}"
  echo ""

  for i in "${!AR_PATHS[@]}"; do
    local wt="${AR_PATHS[$i]}"
    local branch="${AR_BRANCHES[$i]}"
    local short="${branch#autoresearch/}"

    # Merged badge
    local merged_badge=""
    echo "$merged_branches" | grep -qF "$branch" && merged_badge=" ${GREEN}[merged]${NC}"

    # Age
    local age
    age=$(git -C "$wt" log -1 --format="%ar" 2>/dev/null || echo "unknown")

    # Find tmux session whose pane CWD starts with this worktree path
    local sess=""
    while IFS=$'\t' read -r ppath sname; do
      if [[ "$ppath" == "$wt"* ]]; then
        sess="$sname"; break
      fi
    done <<< "$tmux_panes"

    local tmux_label
    if [[ -n "$sess" ]]; then
      if echo "$attached_sessions" | grep -qx "$sess"; then
        tmux_label="${GREEN}в—Ҹ ${sess} (attached)${NC}"
      else
        tmux_label="${YELLOW}в—Ҹ ${sess} (detached)${NC}"
      fi
    else
      tmux_label="${DIM}вҖ” no session${NC}"
    fi

    local stats
    stats=$(experiment_stats "$wt")

    echo -e "  ${ORANGE}${BOLD}${short}${NC}${merged_badge}"
    echo -e "    ${DIM}age:     ${age}${NC}"
    echo -e "    tmux:    ${tmux_label}"
    echo -e "    ${DIM}results: ${stats}${NC}"
    echo ""
  done
}

# ---------------------------------------------------------------------------
# Attach command
# ---------------------------------------------------------------------------

cmd_attach() {
  local slug="${1:-}"
  resolve_repo

  command -v tmux &>/dev/null || fail "tmux not found. Install with: brew install tmux"

  declare -a AR_PATHS=() AR_BRANCHES=()
  collect_ar_worktrees

  # Match each tmux pane's CWD against known worktree paths
  declare -a SESS_NAMES=() SESS_BRANCHES=() SESS_PATHS=()
  while IFS=$'\t' read -r ppath sname; do
    for i in "${!AR_PATHS[@]}"; do
      [[ "$ppath" == "${AR_PATHS[$i]}"* ]] || continue
      local dup=0
      for s in "${SESS_NAMES[@]+"${SESS_NAMES[@]}"}"; do
        [[ "$s" == "$sname" ]] && { dup=1; break; }
      done
      if [[ $dup -eq 0 ]]; then
        SESS_NAMES+=("$sname")
        SESS_BRANCHES+=("${AR_BRANCHES[$i]}")
        SESS_PATHS+=("${AR_PATHS[$i]}")
      fi
      break
    done
  done < <(tmux list-panes -a -F "#{pane_current_path}\t#{session_name}" 2>/dev/null || true)

  if [[ ${#SESS_NAMES[@]} -eq 0 ]]; then
    echo ""
    echo -e "  ${DIM}No active research tmux sessions found.${NC}"
    echo -e "  ${DIM}Run pi-research status to see all worktrees.${NC}"
    echo ""
    exit 0
  fi

  _do_attach() {
    local target="$1"
    if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$target"
    else
      tmux attach-session -t "$target"
    fi
  }

  # Slug provided: match and attach directly
  if [[ -n "$slug" ]]; then
    for i in "${!SESS_NAMES[@]}"; do
      if [[ "${SESS_NAMES[$i]}" == *"$slug"* || "${SESS_BRANCHES[$i]}" == *"$slug"* ]]; then
        echo -e "  ${ORANGE}${BOLD}attaching to ${SESS_NAMES[$i]}вҖҰ${NC}"
        _do_attach "${SESS_NAMES[$i]}"
        exit 0
      fi
    done
    fail "No research session matching '${slug}'"
  fi

  # One session: attach without prompt
  if [[ ${#SESS_NAMES[@]} -eq 1 ]]; then
    echo ""
    echo -e "  ${ORANGE}${BOLD}attaching to ${SESS_NAMES[0]}вҖҰ${NC}"
    echo ""
    _do_attach "${SESS_NAMES[0]}"
    exit 0
  fi

  # Multiple sessions: numbered picker
  echo ""
  echo -e "  ${BOLD}Research sessions:${NC}"
  echo ""
  for i in "${!SESS_NAMES[@]}"; do
    local short="${SESS_BRANCHES[$i]#autoresearch/}"
    echo -e "  ${GREEN}[$((i+1))]${NC}  ${short}"
    echo -e "        ${DIM}${SESS_NAMES[$i]}${NC}"
    echo ""
  done
  read -r -p "  Pick a session [1-${#SESS_NAMES[@]}]: " choice
  local idx=$(( choice - 1 ))
  if [[ $idx -ge 0 && $idx -lt ${#SESS_NAMES[@]} ]]; then
    _do_attach "${SESS_NAMES[$idx]}"
  else
    fail "Invalid choice: $choice"
  fi
}

