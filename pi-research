#!/usr/bin/env bash
set -euo pipefail

# pi-research — launch pi in a fresh git worktree, or clean up old ones
#
# Usage:
#   pi-research [goal]              Single worktree, launches pi
#   pi-research -s N [goal]         N worktrees in tmux splits
#   pi-research status              Dashboard of all active research sessions
#   pi-research attach [slug]       Re-attach to a running tmux session
#   pi-research cleanup             Interactive cleanup of merged worktrees
#   pi-research cleanup --all       Remove all merged worktrees without prompt
#   pi-research cleanup <slug>      Remove a specific worktree by name match

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------

ORANGE='\033[38;5;214m'
AMBER='\033[38;5;208m'
BROWN='\033[38;5;172m'
CREAM='\033[38;5;230m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}$1${NC}"; }
warn()  { echo -e "${YELLOW}⚠ $1${NC}"; }
fail()  { echo -e "${RED}ERROR: $1${NC}" >&2; exit 1; }

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------

print_banner() {
  echo ""
  echo -e "${ORANGE}${BOLD}"
  echo '  ███████╗███╗   ██╗     ██╗ ██████╗ ██╗   ██╗'
  echo '  ██╔════╝████╗  ██║     ██║██╔═══██╗╚██╗ ██╔╝'
  echo '  █████╗  ██╔██╗ ██║     ██║██║   ██║ ╚████╔╝ '
  echo '  ██╔══╝  ██║╚██╗██║██   ██║██║   ██║  ╚██╔╝  '
  echo '  ███████╗██║ ╚████║╚█████╔╝╚██████╔╝   ██║   '
  echo '  ╚══════╝╚═╝  ╚═══╝ ╚════╝  ╚═════╝    ╚═╝   '
  echo -e "${NC}"
  echo -e "            ${CREAM}e x p e r i m e n t i n g${NC}"
  echo ""
  echo -e "                  ${ORANGE}/\\   /\\"
  echo -e "                 /  \\_/  \\"
  echo -e "                | ( o o ) |"
  echo -e "                |   /\\   |"
  echo -e "                 \\  ---  /"
  echo -e "                  '-----'${NC}"
  echo ""
}

# ---------------------------------------------------------------------------
# Animated bun progress bar
# ---------------------------------------------------------------------------

repeat_char() {
  local char="$1" count="$2" result="" i
  for ((i=0; i<count; i++)); do result+="$char"; done
  printf '%s' "$result"
}

# bun_progress <label> <pid...>  — animates until ALL given pids finish
bun_progress() {
  local label="$1"
  shift
  local pids=("$@")
  local width=32 i=0
  local frames=('(\(\  ' '(•ω•) ' '(/(\  ' '(•ω•) ')

  while true; do
    local running=0
    for pid in "${pids[@]}"; do
      kill -0 "$pid" 2>/dev/null && running=1 && break
    done
    [[ $running -eq 0 ]] && break
    local filled=$(( i % (width + 1) ))
    local bar
    bar="$(repeat_char '█' "$filled")$(repeat_char '░' "$((width - filled))")"
    printf '\r  %-22s \033[38;5;214m[\033[0m%s\033[38;5;214m]\033[0m \033[38;5;172m%s\033[0m' \
      "$label" "$bar" "${frames[$((i % 4))]}"
    ((i++)) || true
    sleep 0.04
  done

  local bar
  bar="$(repeat_char '█' "$width")"
  printf '\r  %-22s \033[38;5;214m[\033[0m%s\033[38;5;214m]\033[0m \033[32m✓\033[0m\n' \
    "$label" "$bar"
}

# ---------------------------------------------------------------------------
# Shared: collect autoresearch/* worktrees into AR_PATHS / AR_BRANCHES
# ---------------------------------------------------------------------------

collect_ar_worktrees() {
  AR_PATHS=()
  AR_BRANCHES=()
  local cur_path="" cur_branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        if [[ -n "$cur_path" && "$cur_branch" == refs/heads/autoresearch/* ]]; then
          AR_PATHS+=("$cur_path"); AR_BRANCHES+=("${cur_branch#refs/heads/}")
        fi
        cur_path="${line#worktree }"; cur_branch=""
        ;;
      "branch "*) cur_branch="${line#branch }" ;;
    esac
  done < <(git -C "$REPO_ROOT" worktree list --porcelain)
  if [[ -n "$cur_path" && "$cur_branch" == refs/heads/autoresearch/* ]]; then
    AR_PATHS+=("$cur_path"); AR_BRANCHES+=("${cur_branch#refs/heads/}")
  fi
}

# ---------------------------------------------------------------------------
# Status command
# ---------------------------------------------------------------------------

cmd_status() {
  resolve_repo

  declare -a AR_PATHS=() AR_BRANCHES=()
  collect_ar_worktrees

  if [[ ${#AR_PATHS[@]} -eq 0 ]]; then
    echo ""
    echo -e "  ${DIM}No autoresearch worktrees found. Run pi-research to start one.${NC}"
    echo ""
    exit 0
  fi

  # Collect tmux state as plain text (bash 3.2: no associative arrays)
  local tmux_panes="" attached_sessions=""
  if command -v tmux &>/dev/null; then
    tmux_panes=$(tmux list-panes -a \
      -F "#{pane_current_path}\t#{session_name}" 2>/dev/null || true)
    attached_sessions=$(tmux list-sessions \
      -F "#{session_name} #{session_attached}" 2>/dev/null \
      | awk '$2==1{print $1}' || true)
  fi

  # Merged branches as plain text
  local merged_branches
  merged_branches=$(git -C "$REPO_ROOT" branch --merged "$BASE_BRANCH" \
    --list 'autoresearch/*' 2>/dev/null || true)

  echo ""
  echo -e "  ${BOLD}Research sessions${NC}  ${DIM}repo: ${REPO_NAME}  base: ${BASE_BRANCH}${NC}"
  echo ""

  for i in "${!AR_PATHS[@]}"; do
    local wt="${AR_PATHS[$i]}"
    local branch="${AR_BRANCHES[$i]}"
    local short="${branch#autoresearch/}"

    # Merged badge
    local merged_badge=""
    echo "$merged_branches" | grep -qF "$branch" && merged_badge=" ${GREEN}[merged]${NC}"

    # Age
    local age
    age=$(git -C "$wt" log -1 --format="%ar" 2>/dev/null || echo "unknown")

    # Find tmux session whose pane CWD starts with this worktree path
    local sess=""
    while IFS=$'\t' read -r ppath sname; do
      if [[ "$ppath" == "$wt"* ]]; then
        sess="$sname"; break
      fi
    done <<< "$tmux_panes"

    local tmux_label
    if [[ -n "$sess" ]]; then
      if echo "$attached_sessions" | grep -qx "$sess"; then
        tmux_label="${GREEN}● ${sess} (attached)${NC}"
      else
        tmux_label="${YELLOW}● ${sess} (detached)${NC}"
      fi
    else
      tmux_label="${DIM}— no session${NC}"
    fi

    local stats
    stats=$(experiment_stats "$wt")

    echo -e "  ${ORANGE}${BOLD}${short}${NC}${merged_badge}"
    echo -e "    ${DIM}age:     ${age}${NC}"
    echo -e "    tmux:    ${tmux_label}"
    echo -e "    ${DIM}results: ${stats}${NC}"
    echo ""
  done
}

# ---------------------------------------------------------------------------
# Attach command
# ---------------------------------------------------------------------------

cmd_attach() {
  local slug="${1:-}"
  resolve_repo

  command -v tmux &>/dev/null || fail "tmux not found. Install with: brew install tmux"

  declare -a AR_PATHS=() AR_BRANCHES=()
  collect_ar_worktrees

  # Match each tmux pane's CWD against known worktree paths
  declare -a SESS_NAMES=() SESS_BRANCHES=() SESS_PATHS=()
  while IFS=$'\t' read -r ppath sname; do
    for i in "${!AR_PATHS[@]}"; do
      [[ "$ppath" == "${AR_PATHS[$i]}"* ]] || continue
      local dup=0
      for s in "${SESS_NAMES[@]+"${SESS_NAMES[@]}"}"; do
        [[ "$s" == "$sname" ]] && { dup=1; break; }
      done
      if [[ $dup -eq 0 ]]; then
        SESS_NAMES+=("$sname")
        SESS_BRANCHES+=("${AR_BRANCHES[$i]}")
        SESS_PATHS+=("${AR_PATHS[$i]}")
      fi
      break
    done
  done < <(tmux list-panes -a -F "#{pane_current_path}\t#{session_name}" 2>/dev/null || true)

  if [[ ${#SESS_NAMES[@]} -eq 0 ]]; then
    echo ""
    echo -e "  ${DIM}No active research tmux sessions found.${NC}"
    echo -e "  ${DIM}Run pi-research status to see all worktrees.${NC}"
    echo ""
    exit 0
  fi

  _do_attach() {
    local target="$1"
    if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$target"
    else
      tmux attach-session -t "$target"
    fi
  }

  # Slug provided: match and attach directly
  if [[ -n "$slug" ]]; then
    for i in "${!SESS_NAMES[@]}"; do
      if [[ "${SESS_NAMES[$i]}" == *"$slug"* || "${SESS_BRANCHES[$i]}" == *"$slug"* ]]; then
        echo -e "  ${ORANGE}${BOLD}attaching to ${SESS_NAMES[$i]}…${NC}"
        _do_attach "${SESS_NAMES[$i]}"
        exit 0
      fi
    done
    fail "No research session matching '${slug}'"
  fi

  # One session: attach without prompt
  if [[ ${#SESS_NAMES[@]} -eq 1 ]]; then
    echo ""
    echo -e "  ${ORANGE}${BOLD}attaching to ${SESS_NAMES[0]}…${NC}"
    echo ""
    _do_attach "${SESS_NAMES[0]}"
    exit 0
  fi

  # Multiple sessions: numbered picker
  echo ""
  echo -e "  ${BOLD}Research sessions:${NC}"
  echo ""
  for i in "${!SESS_NAMES[@]}"; do
    local short="${SESS_BRANCHES[$i]#autoresearch/}"
    echo -e "  ${GREEN}[$((i+1))]${NC}  ${short}"
    echo -e "        ${DIM}${SESS_NAMES[$i]}${NC}"
    echo ""
  done
  read -r -p "  Pick a session [1-${#SESS_NAMES[@]}]: " choice
  local idx=$(( choice - 1 ))
  if [[ $idx -ge 0 && $idx -lt ${#SESS_NAMES[@]} ]]; then
    _do_attach "${SESS_NAMES[$idx]}"
  else
    fail "Invalid choice: $choice"
  fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
  echo ""
  echo -e "${ORANGE}${BOLD}Usage:${NC} pi-research ${DIM}[command] [options]${NC}"
  echo ""
  echo -e "${BOLD}Commands:${NC}"
  echo -e "  ${GREEN}<goal>${NC}               Create a worktree and launch pi"
  echo -e "  ${GREEN}-s N <goal>${NC}          Create N worktrees in tmux splits"
  echo -e "  ${GREEN}status${NC}               Dashboard of all active research sessions"
  echo -e "  ${GREEN}attach [slug]${NC}        Re-attach to a running tmux session"
  echo -e "  ${GREEN}cleanup${NC}              Interactive cleanup of merged autoresearch worktrees"
  echo -e "  ${GREEN}cleanup --all${NC}        Remove all merged worktrees without prompt"
  echo -e "  ${GREEN}cleanup <slug>${NC}       Remove a specific worktree by name match"
  echo -e "  ${GREEN}help${NC}                 Show this help message"
  echo ""
  echo -e "${BOLD}Examples:${NC}"
  echo -e "  ${DIM}pi-research${NC}"
  echo -e "  ${DIM}pi-research optimize-tests${NC}"
  echo -e "  ${DIM}pi-research -s 3 optimize-bundle${NC}"
  echo -e "  ${DIM}pi-research cleanup${NC}"
  echo -e "  ${DIM}pi-research cleanup --all${NC}"
  echo -e "  ${DIM}pi-research cleanup optimize-tests${NC}"
  echo ""
  exit 0
}

# ---------------------------------------------------------------------------
# Shared: resolve repo context
# ---------------------------------------------------------------------------

resolve_repo() {
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) \
    || fail "Not in a git repository."
  REPO_NAME=$(basename "$REPO_ROOT")
  BASE_BRANCH=$(git -C "$REPO_ROOT" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|refs/remotes/origin/||') \
    || BASE_BRANCH=$(git -C "$REPO_ROOT" branch --list main master \
       | head -1 | tr -d ' *') \
    || BASE_BRANCH="main"
}

# ---------------------------------------------------------------------------
# Cleanup command
# ---------------------------------------------------------------------------

# Read experiment stats from a worktree's autoresearch.jsonl
experiment_stats() {
  local wt_dir="$1"
  local jsonl="${wt_dir}/autoresearch.jsonl"
  if [[ -f "$jsonl" ]]; then
    local total kept
    total=$(grep -c '"commit"' "$jsonl" 2>/dev/null || echo 0)
    kept=$(grep -c '"status":"keep"' "$jsonl" 2>/dev/null || echo 0)
    echo "${kept} kept / ${total} total"
  else
    echo "no experiments"
  fi
}

# Remove a single worktree + its branch
remove_worktree() {
  local wt_path="$1"
  local branch="$2"
  local label
  label=$(basename "$wt_path")

  git -C "$REPO_ROOT" worktree remove "$wt_path" --force 2>/dev/null \
    || { rm -rf "$wt_path"; git -C "$REPO_ROOT" worktree prune 2>/dev/null || true; }

  git -C "$REPO_ROOT" branch -d "$branch" 2>/dev/null \
    || git -C "$REPO_ROOT" branch -D "$branch" 2>/dev/null \
    || true

  echo -e "  ${GREEN}✓${NC} removed ${DIM}${label}${NC}"
}

cmd_cleanup() {
  local mode="${1:-interactive}"   # interactive | --all | <slug>

  resolve_repo

  # ── Collect all autoresearch/* worktrees ──────────────────────────────────
  declare -a AR_PATHS=() AR_BRANCHES=()
  collect_ar_worktrees
  declare -a WT_PATHS=("${AR_PATHS[@]+"${AR_PATHS[@]}"}")
  declare -a WT_BRANCHES=("${AR_BRANCHES[@]+"${AR_BRANCHES[@]}"}")

  # ── Orphaned branches (autoresearch/* with no linked worktree) ────────────
  declare -a ORPHAN_BRANCHES=()
  while IFS= read -r b; do
    b="${b#  }"; b="${b# }"; b="${b#\* }"
    [[ -z "$b" ]] && continue
    local found=0
    for wb in "${WT_BRANCHES[@]+"${WT_BRANCHES[@]}"}"; do
      [[ "$wb" == "$b" ]] && { found=1; break; }
    done
    [[ $found -eq 0 ]] && ORPHAN_BRANCHES+=("$b")
  done < <(git -C "$REPO_ROOT" branch --list 'autoresearch/*')

  local total_count=$(( ${#WT_PATHS[@]} + ${#ORPHAN_BRANCHES[@]} ))
  if [[ $total_count -eq 0 ]]; then
    echo ""
    echo -e "  ${DIM}No autoresearch worktrees or branches found.${NC}"
    echo ""
    exit 0
  fi

  # ── Merged branch set (plain text, bash 3.2 compat) ─────────────────────
  local MERGED_SET
  MERGED_SET=$(git -C "$REPO_ROOT" branch --merged "$BASE_BRANCH" \
    --list 'autoresearch/*' 2>/dev/null || true)

  # ── Slug-match mode: remove one specific worktree ─────────────────────────
  if [[ "$mode" != "interactive" && "$mode" != "--all" ]]; then
    local slug="$mode"
    local matched_path="" matched_branch=""
    for idx in "${!WT_BRANCHES[@]}"; do
      if [[ "${WT_BRANCHES[$idx]}" == *"$slug"* ]]; then
        matched_path="${WT_PATHS[$idx]}"
        matched_branch="${WT_BRANCHES[$idx]}"
        break
      fi
    done
    for b in "${ORPHAN_BRANCHES[@]+"${ORPHAN_BRANCHES[@]}"}"; do
      if [[ "$b" == *"$slug"* ]]; then
        matched_branch="$b"
        break
      fi
    done

    if [[ -z "$matched_branch" ]]; then
      fail "No autoresearch worktree or branch matching '${slug}'"
    fi

    echo ""
    echo -e "  ${YELLOW}Removing:${NC} ${matched_branch}"
    if [[ -n "$matched_path" ]]; then
      echo -e "  ${DIM}path: ${matched_path}${NC}"
    fi
    echo ""
    read -r -p "  Confirm? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }
    echo ""
    remove_worktree "$matched_path" "$matched_branch"
    echo ""
    exit 0
  fi

  # ── Display table ─────────────────────────────────────────────────────────
  echo ""
  echo -e "  ${BOLD}Autoresearch worktrees${NC}  ${DIM}(base: ${BASE_BRANCH})${NC}"
  echo -e "  ${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""

  declare -a MERGED_PATHS=()
  declare -a MERGED_BRANCHES=()

  local idx=1
  for i in "${!WT_PATHS[@]}"; do
    local wt="${WT_PATHS[$i]}"
    local branch="${WT_BRANCHES[$i]}"
    local stats
    stats=$(experiment_stats "$wt")
    local short_branch="${branch#autoresearch/}"

    if echo "$MERGED_SET" | grep -qF "$branch"; then
      echo -e "  ${GREEN}[${idx}] ✓ merged${NC}   ${branch}"
      MERGED_PATHS+=("$wt")
      MERGED_BRANCHES+=("$branch")
    else
      echo -e "  ${DIM}[−] ○ active${NC}   ${branch}"
    fi
    echo -e "        ${DIM}${wt}${NC}"
    echo -e "        ${DIM}${stats}${NC}"
    echo ""
    ((idx++)) || true
  done

  if [[ ${#ORPHAN_BRANCHES[@]} -gt 0 ]]; then
    echo -e "  ${DIM}Orphaned branches (no worktree):${NC}"
    for b in "${ORPHAN_BRANCHES[@]}"; do
      if echo "$MERGED_SET" | grep -qF "$b"; then
        echo -e "  ${GREEN}[${idx}] ✓ merged${NC}   ${b}"
        MERGED_BRANCHES+=("$b")
        MERGED_PATHS+=("")
      else
        echo -e "  ${DIM}[−] ○ active   ${b}${NC}"
      fi
      ((idx++)) || true
    done
    echo ""
  fi

  local merged_count=${#MERGED_BRANCHES[@]}

  if [[ $merged_count -eq 0 ]]; then
    echo -e "  ${DIM}No merged worktrees to clean up.${NC}"
    echo ""
    exit 0
  fi

  echo -e "  ${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo -e "  ${merged_count} merged worktree(s) can be removed."
  echo ""

  # ── Confirm ───────────────────────────────────────────────────────────────
  if [[ "$mode" != "--all" ]]; then
    read -r -p "  Remove all merged? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }
  fi

  echo ""

  # ── Remove ────────────────────────────────────────────────────────────────
  for i in "${!MERGED_BRANCHES[@]}"; do
    remove_worktree "${MERGED_PATHS[$i]}" "${MERGED_BRANCHES[$i]}"
  done

  echo ""
  echo -e "  ${GREEN}${BOLD}Done.${NC} ${merged_count} worktree(s) removed."
  echo ""
}

# ---------------------------------------------------------------------------
# Parse args — route to cleanup or worktree creation
# ---------------------------------------------------------------------------

if [[ "${1:-}" == "status" ]]; then
  resolve_repo
  cmd_status
  exit 0
fi

if [[ "${1:-}" == "attach" ]]; then
  shift
  cmd_attach "${1:-}"
  exit 0
fi

if [[ "${1:-}" == "cleanup" ]]; then
  shift
  resolve_repo
  cmd_cleanup "${1:-interactive}"
  exit 0
fi

if [[ "${1:-}" == "help" ]]; then
  usage
fi

SPLITS=1
GOAL=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s)
      [[ $# -ge 2 ]] || fail "-s requires a number"
      SPLITS="$2"
      shift 2
      ;;
    -h|--help|-help) usage ;;
    -*) fail "Unknown flag: $1" ;;
    *)
      GOAL="$1"
      shift
      ;;
  esac
done

[[ "$SPLITS" =~ ^[1-9][0-9]*$ ]] || fail "-s requires a positive integer, got: $SPLITS"
[[ "$SPLITS" -le 9 ]] || fail "-s max is 9 splits"

# ---------------------------------------------------------------------------
# Repo context
# ---------------------------------------------------------------------------

resolve_repo

TIMESTAMP=$(date +%Y%m%d-%H%M%S)

if [[ -n "$GOAL" ]]; then
  GOAL_SLUG=$(echo "$GOAL" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
else
  GOAL_SLUG="session"
fi

# ---------------------------------------------------------------------------
# Print banner
# ---------------------------------------------------------------------------

print_banner

echo -e "  ${DIM}repo:   ${REPO_NAME}${NC}"
echo -e "  ${DIM}base:   ${BASE_BRANCH}${NC}"
echo -e "  ${DIM}splits: ${SPLITS}${NC}"
echo ""

# ---------------------------------------------------------------------------
# Create worktrees
# ---------------------------------------------------------------------------

WORKTREES=()
BRANCHES=()
WT_PIDS=()
WT_LOGS=()

# Compute all paths/branches and fire git worktree add in parallel
for i in $(seq 1 "$SPLITS"); do
  if [[ "$SPLITS" -eq 1 ]]; then
    BRANCH="autoresearch/${GOAL_SLUG}-${TIMESTAMP}"
    WORKTREE_DIR="${REPO_ROOT}/../${REPO_NAME}-research-${GOAL_SLUG}-${TIMESTAMP}"
  else
    BRANCH="autoresearch/${GOAL_SLUG}-${TIMESTAMP}-${i}"
    WORKTREE_DIR="${REPO_ROOT}/../${REPO_NAME}-research-${GOAL_SLUG}-${TIMESTAMP}-${i}"
  fi

  WORKTREES+=("$WORKTREE_DIR")
  BRANCHES+=("$BRANCH")
  WT_LOGS+=("$(mktemp)")

  git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" -b "$BRANCH" "$BASE_BRANCH" \
    >"${WT_LOGS[-1]}" 2>&1 &
  WT_PIDS+=($!)
done

# Single progress bar covers all parallel jobs
if [[ "$SPLITS" -eq 1 ]]; then
  bun_progress "[1/1] $(basename "${WORKTREES[0]}")" "${WT_PIDS[0]}"
else
  bun_progress "creating ${SPLITS} worktrees" "${WT_PIDS[@]}"
fi

# Collect results — fail fast on any error, print summary for successes
for i in "${!WT_PIDS[@]}"; do
  wait "${WT_PIDS[$i]}" || {
    echo ""
    cat "${WT_LOGS[$i]}" >&2
    fail "Failed to create worktree: ${BRANCHES[$i]}"
  }
  echo -e "  ${GREEN}✓${NC}  ${DIM}$(basename "${WORKTREES[$i]}")${NC}"
  echo -e "      ${DIM}↳ branch:   ${BRANCHES[$i]}${NC}"
  echo -e "      ${DIM}↳ worktree: ${WORKTREES[$i]}${NC}"
  rm -f "${WT_LOGS[$i]}"
done

echo ""

# ---------------------------------------------------------------------------
# Launch
# ---------------------------------------------------------------------------

if [[ "$SPLITS" -eq 1 ]]; then
  echo -e "  ${ORANGE}${BOLD}✦ now on worktree 1 / 1${NC}"
  echo -e "  ${DIM}$(basename "${WORKTREES[0]}")${NC}"
  echo ""
  echo -e "  ${ORANGE}${BOLD}launching pi…${NC}"
  echo ""
  cd "${WORKTREES[0]}"
  exec pi

else
  command -v tmux &>/dev/null || {
    warn "tmux not found. Install with: brew install tmux"
    echo ""
    echo "Worktrees created. Launch pi manually in each:"
    for wt in "${WORKTREES[@]}"; do
      echo "  cd $wt && pi"
    done
    exit 1
  }

  SESSION="ar-${GOAL_SLUG}-${TIMESTAMP}"

  if [[ "$SPLITS" -le 3 ]]; then
    LAYOUT="even-horizontal"
  else
    LAYOUT="tiled"
  fi

  echo ""
  for i in "${!WORKTREES[@]}"; do
    echo -e "  ${ORANGE}${BOLD}✦ worktree $((i+1)) / ${SPLITS}${NC}  ${DIM}$(basename "${WORKTREES[$i]}")${NC}"
  done
  echo ""
  echo -e "  ${ORANGE}${BOLD}opening ${SPLITS} tmux panes…${NC}"
  echo ""

  if [[ -n "${TMUX:-}" ]]; then
    tmux new-window -c "${WORKTREES[0]}" -n "$GOAL_SLUG"
    tmux send-keys "pi" Enter

    for i in $(seq 1 $((SPLITS - 1))); do
      tmux split-window -c "${WORKTREES[$i]}"
      tmux send-keys "pi" Enter
      tmux select-layout "$LAYOUT"
    done

    tmux select-pane -t 0
  else
    tmux new-session -d -s "$SESSION" -c "${WORKTREES[0]}"
    tmux send-keys -t "$SESSION" "pi" Enter

    for i in $(seq 1 $((SPLITS - 1))); do
      tmux split-window -t "$SESSION" -c "${WORKTREES[$i]}"
      tmux send-keys -t "$SESSION" "pi" Enter
      tmux select-layout -t "$SESSION" "$LAYOUT"
    done

    tmux select-pane -t "$SESSION:0.0"
    tmux attach-session -t "$SESSION"
  fi
fi
