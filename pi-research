# Usage
# ---------------------------------------------------------------------------

usage() {
  echo ""
  echo -e "${ORANGE}${BOLD}Usage:${NC} pi-research ${DIM}[command] [options]${NC}"
  echo ""
  echo -e "${BOLD}Commands:${NC}"
  echo -e "  ${GREEN}<goal>${NC}               Create a worktree and launch pi"
  echo -e "  ${GREEN}-s N <goal>${NC}          Create N worktrees in tmux splits"
  echo -e "  ${GREEN}status${NC}               Dashboard of all active research sessions"
  echo -e "  ${GREEN}attach [slug]${NC}        Re-attach to a running tmux session"
  echo -e "  ${GREEN}cleanup${NC}              Interactive cleanup of merged autoresearch worktrees"
  echo -e "  ${GREEN}cleanup --all${NC}        Remove all merged worktrees without prompt"
  echo -e "  ${GREEN}cleanup <slug>${NC}       Remove a specific worktree by name match"
  echo -e "  ${GREEN}help${NC}                 Show this help message"
  echo ""
  echo -e "${BOLD}Examples:${NC}"
  echo -e "  ${DIM}pi-research${NC}"
  echo -e "  ${DIM}pi-research optimize-tests${NC}"
  echo -e "  ${DIM}pi-research -s 3 optimize-bundle${NC}"
  echo -e "  ${DIM}pi-research cleanup${NC}"
  echo -e "  ${DIM}pi-research cleanup --all${NC}"
  echo -e "  ${DIM}pi-research cleanup optimize-tests${NC}"
  echo ""
  exit 0
}

# ---------------------------------------------------------------------------
# Shared: resolve repo context
# ---------------------------------------------------------------------------

resolve_repo() {
  REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) \
    || fail "Not in a git repository."
  REPO_NAME=$(basename "$REPO_ROOT")
  BASE_BRANCH=$(git -C "$REPO_ROOT" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|refs/remotes/origin/||') \
    || BASE_BRANCH=$(git -C "$REPO_ROOT" branch --list main master \
       | head -1 | tr -d ' *') \
    || BASE_BRANCH="main"
}

# ---------------------------------------------------------------------------
# Cleanup command
# ---------------------------------------------------------------------------

# Read experiment stats from a worktree's autoresearch.jsonl
experiment_stats() {
  local wt_dir="$1"
  local jsonl="${wt_dir}/autoresearch.jsonl"
  if [[ -f "$jsonl" ]]; then
    local total kept
    total=$(grep -c '"commit"' "$jsonl" 2>/dev/null || echo 0)
    kept=$(grep -c '"status":"keep"' "$jsonl" 2>/dev/null || echo 0)
    echo "${kept} kept / ${total} total"
  else
    echo "no experiments"
  fi
}

# Remove a single worktree + its branch
remove_worktree() {
  local wt_path="$1"
  local branch="$2"
  local label
  label=$(basename "$wt_path")

  git -C "$REPO_ROOT" worktree remove "$wt_path" --force 2>/dev/null \
    || { rm -rf "$wt_path"; git -C "$REPO_ROOT" worktree prune 2>/dev/null || true; }

  git -C "$REPO_ROOT" branch -d "$branch" 2>/dev/null \
    || git -C "$REPO_ROOT" branch -D "$branch" 2>/dev/null \
    || true

  echo -e "  ${GREEN}вң“${NC} removed ${DIM}${label}${NC}"
}

cmd_cleanup() {
  local mode="${1:-interactive}"   # interactive | --all | <slug>

  resolve_repo

  # в”Җв”Җ Collect all autoresearch/* worktrees в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  declare -a AR_PATHS=() AR_BRANCHES=()
  collect_ar_worktrees
  declare -a WT_PATHS=("${AR_PATHS[@]+"${AR_PATHS[@]}"}")
  declare -a WT_BRANCHES=("${AR_BRANCHES[@]+"${AR_BRANCHES[@]}"}")

  # в”Җв”Җ Orphaned branches (autoresearch/* with no linked worktree) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  declare -a ORPHAN_BRANCHES=()
  while IFS= read -r b; do
    b="${b#  }"; b="${b# }"; b="${b#\* }"
    [[ -z "$b" ]] && continue
    local found=0
    for wb in "${WT_BRANCHES[@]+"${WT_BRANCHES[@]}"}"; do
      [[ "$wb" == "$b" ]] && { found=1; break; }
    done
    [[ $found -eq 0 ]] && ORPHAN_BRANCHES+=("$b")
  done < <(git -C "$REPO_ROOT" branch --list 'autoresearch/*')

  local total_count=$(( ${#WT_PATHS[@]} + ${#ORPHAN_BRANCHES[@]} ))
  if [[ $total_count -eq 0 ]]; then
    echo ""
    echo -e "  ${DIM}No autoresearch worktrees or branches found.${NC}"
    echo ""
    exit 0
  fi

  # в”Җв”Җ Merged branch set (plain text, bash 3.2 compat) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  local MERGED_SET
  MERGED_SET=$(git -C "$REPO_ROOT" branch --merged "$BASE_BRANCH" \
    --list 'autoresearch/*' 2>/dev/null || true)

  # в”Җв”Җ Slug-match mode: remove one specific worktree в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if [[ "$mode" != "interactive" && "$mode" != "--all" ]]; then
    local slug="$mode"
    local matched_path="" matched_branch=""
    for idx in "${!WT_BRANCHES[@]}"; do
      if [[ "${WT_BRANCHES[$idx]}" == *"$slug"* ]]; then
        matched_path="${WT_PATHS[$idx]}"
        matched_branch="${WT_BRANCHES[$idx]}"
        break
      fi
    done
    for b in "${ORPHAN_BRANCHES[@]+"${ORPHAN_BRANCHES[@]}"}"; do
      if [[ "$b" == *"$slug"* ]]; then
        matched_branch="$b"
        break
      fi
    done

    if [[ -z "$matched_branch" ]]; then
      fail "No autoresearch worktree or branch matching '${slug}'"
    fi

    echo ""
    echo -e "  ${YELLOW}Removing:${NC} ${matched_branch}"
    if [[ -n "$matched_path" ]]; then
      echo -e "  ${DIM}path: ${matched_path}${NC}"
    fi
    echo ""
    read -r -p "  Confirm? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }
    echo ""
    remove_worktree "$matched_path" "$matched_branch"
    echo ""
    exit 0
  fi

  # в”Җв”Җ Display table в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  echo ""
  echo -e "  ${BOLD}Autoresearch worktrees${NC}  ${DIM}(base: ${BASE_BRANCH})${NC}"
  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
  echo ""

  declare -a MERGED_PATHS=()
  declare -a MERGED_BRANCHES=()

  local idx=1
  for i in "${!WT_PATHS[@]}"; do
    local wt="${WT_PATHS[$i]}"
    local branch="${WT_BRANCHES[$i]}"
    local stats
    stats=$(experiment_stats "$wt")
    local short_branch="${branch#autoresearch/}"

    if echo "$MERGED_SET" | grep -qF "$branch"; then
      echo -e "  ${GREEN}[${idx}] вң“ merged${NC}   ${branch}"
      MERGED_PATHS+=("$wt")
      MERGED_BRANCHES+=("$branch")
    else
      echo -e "  ${DIM}[вҲ’] в—Ӣ active${NC}   ${branch}"
    fi
    echo -e "        ${DIM}${wt}${NC}"
    echo -e "        ${DIM}${stats}${NC}"
    echo ""
    ((idx++)) || true
  done

  if [[ ${#ORPHAN_BRANCHES[@]} -gt 0 ]]; then
    echo -e "  ${DIM}Orphaned branches (no worktree):${NC}"
    for b in "${ORPHAN_BRANCHES[@]}"; do
      if echo "$MERGED_SET" | grep -qF "$b"; then
        echo -e "  ${GREEN}[${idx}] вң“ merged${NC}   ${b}"
        MERGED_BRANCHES+=("$b")
        MERGED_PATHS+=("")
      else
        echo -e "  ${DIM}[вҲ’] в—Ӣ active   ${b}${NC}"
      fi
      ((idx++)) || true
    done
    echo ""
  fi

  local merged_count=${#MERGED_BRANCHES[@]}

  if [[ $merged_count -eq 0 ]]; then
    echo -e "  ${DIM}No merged worktrees to clean up.${NC}"
    echo ""
    exit 0
  fi

  echo -e "  ${DIM}в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ${NC}"
  echo ""
  echo -e "  ${merged_count} merged worktree(s) can be removed."
  echo ""

  # в”Җв”Җ Confirm в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if [[ "$mode" != "--all" ]]; then
    read -r -p "  Remove all merged? [y/N] " confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }
  fi

  echo ""

  # в”Җв”Җ Remove в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  for i in "${!MERGED_BRANCHES[@]}"; do
    remove_worktree "${MERGED_PATHS[$i]}" "${MERGED_BRANCHES[$i]}"
  done

  echo ""
  echo -e "  ${GREEN}${BOLD}Done.${NC} ${merged_count} worktree(s) removed."
  echo ""
}

# ---------------------------------------------------------------------------
# Parse args вҖ” route to cleanup or worktree creation
# ---------------------------------------------------------------------------

if [[ "${1:-}" == "status" ]]; then
  resolve_repo
  cmd_status
  exit 0
fi

if [[ "${1:-}" == "attach" ]]; then
  shift
  cmd_attach "${1:-}"
  exit 0
fi

if [[ "${1:-}" == "cleanup" ]]; then
  shift
  resolve_repo
  cmd_cleanup "${1:-interactive}"
  exit 0
fi

if [[ "${1:-}" == "help" ]]; then
  usage
fi

SPLITS=1
GOAL=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s)
      [[ $# -ge 2 ]] || fail "-s requires a number"
      SPLITS="$2"
      shift 2
      ;;
    -h|--help|-help) usage ;;
    -*) fail "Unknown flag: $1" ;;
    *)
      GOAL="$1"
      shift
      ;;
  esac
done

[[ "$SPLITS" =~ ^[1-9][0-9]*$ ]] || fail "-s requires a positive integer, got: $SPLITS"
[[ "$SPLITS" -le 9 ]] || fail "-s max is 9 splits"

# ---------------------------------------------------------------------------
# Repo context
# ---------------------------------------------------------------------------

resolve_repo

TIMESTAMP=$(date +%Y%m%d-%H%M%S)

if [[ -n "$GOAL" ]]; then
  GOAL_SLUG=$(echo "$GOAL" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd '[:alnum:]-')
else
  GOAL_SLUG="session"
fi

# ---------------------------------------------------------------------------
# Print banner
# ---------------------------------------------------------------------------

print_banner

echo -e "  ${DIM}repo:   ${REPO_NAME}${NC}"
echo -e "  ${DIM}base:   ${BASE_BRANCH}${NC}"
echo -e "  ${DIM}splits: ${SPLITS}${NC}"
echo ""

# ---------------------------------------------------------------------------
# Create worktrees вҖ” pool-first, parallel git worktree add as fallback
# ---------------------------------------------------------------------------

BASE_COMMIT=$(git -C "$REPO_ROOT" rev-parse "$BASE_BRANCH" 2>/dev/null || true)
POOL_HOME=$(pool_dir)
pool_prune "$POOL_HOME" "$BASE_COMMIT"

WORKTREES=()
BRANCHES=()
WT_PIDS=()
WT_LOGS=()
POOL_HITS=0

for i in $(seq 1 "$SPLITS"); do
  if [[ "$SPLITS" -eq 1 ]]; then
    BRANCH="autoresearch/${GOAL_SLUG}-${TIMESTAMP}"
    WORKTREE_DIR="${REPO_ROOT}/../${REPO_NAME}-research-${GOAL_SLUG}-${TIMESTAMP}"
  else
    BRANCH="autoresearch/${GOAL_SLUG}-${TIMESTAMP}-${i}"
    WORKTREE_DIR="${REPO_ROOT}/../${REPO_NAME}-research-${GOAL_SLUG}-${TIMESTAMP}-${i}"
  fi
  WORKTREES+=("$WORKTREE_DIR")
  BRANCHES+=("$BRANCH")

  if pool_claim "$POOL_HOME" "$WORKTREE_DIR" "$BRANCH" "$BASE_COMMIT"; then
    WT_PIDS+=("")
    WT_LOGS+=("")
    POOL_HITS=$(( POOL_HITS + 1 ))
  else
    WT_LOGS+=("$(mktemp)")
    git -C "$REPO_ROOT" -c checkout.workers="$(cpu_count)" \
      worktree add "$WORKTREE_DIR" -b "$BRANCH" "$BASE_BRANCH" \
      >"${WT_LOGS[-1]}" 2>&1 &
    WT_PIDS+=($!)
  fi
done

# Collect PIDs that actually need waiting
ACTIVE_PIDS=()
for _pid in "${WT_PIDS[@]+"${WT_PIDS[@]}"}"; do
  [[ -n "$_pid" ]] && ACTIVE_PIDS+=("$_pid") || true
done

if [[ ${#ACTIVE_PIDS[@]} -gt 0 ]]; then
  FRESH=$(( SPLITS - POOL_HITS ))
  if [[ "$SPLITS" -eq 1 ]]; then
    bun_progress "[1/1] $(basename "${WORKTREES[0]}")" "${ACTIVE_PIDS[0]}"
  else
    bun_progress "creating ${FRESH} worktrees" "${ACTIVE_PIDS[@]}"
  fi
elif [[ $POOL_HITS -gt 0 ]]; then
  echo -e "  ${GREEN}вҡЎ all ${POOL_HITS} from pool вҖ” instant!${NC}"
fi

for i in "${!WT_PIDS[@]}"; do
  _pid="${WT_PIDS[$i]}"
  if [[ -n "$_pid" ]]; then
    wait "$_pid" || {
      echo ""
      cat "${WT_LOGS[$i]}" >&2
      fail "Failed to create worktree: ${BRANCHES[$i]}"
    }
    rm -f "${WT_LOGS[$i]}"
    echo -e "  ${GREEN}вң“${NC}  ${DIM}$(basename "${WORKTREES[$i]}")${NC}"
  else
    echo -e "  ${GREEN}вҡЎ${NC}  ${DIM}$(basename "${WORKTREES[$i]}")${NC}  ${DIM}(pool)${NC}"
  fi
  echo -e "      ${DIM}вҶі branch:   ${BRANCHES[$i]}${NC}"
  echo -e "      ${DIM}вҶі worktree: ${WORKTREES[$i]}${NC}"
done

echo ""

# Silently refill pool in background so next run is fast too
( pool_replenish ) >/dev/null 2>&1 &
disown 2>/dev/null || true

# ---------------------------------------------------------------------------
# Launch
# ---------------------------------------------------------------------------

if [[ "$SPLITS" -eq 1 ]]; then
  echo -e "  ${ORANGE}${BOLD}вңҰ now on worktree 1 / 1${NC}"
  echo -e "  ${DIM}$(basename "${WORKTREES[0]}")${NC}"
  echo ""
  echo -e "  ${ORANGE}${BOLD}launching piвҖҰ${NC}"
  echo ""
  cd "${WORKTREES[0]}"
  exec pi

else
  command -v tmux &>/dev/null || {
    warn "tmux not found. Install with: brew install tmux"
    echo ""
    echo "Worktrees created. Launch pi manually in each:"
    for wt in "${WORKTREES[@]}"; do
      echo "  cd $wt && pi"
    done
    exit 1
  }

  SESSION="ar-${GOAL_SLUG}-${TIMESTAMP}"

  if [[ "$SPLITS" -le 3 ]]; then
    LAYOUT="even-horizontal"
  else
    LAYOUT="tiled"
  fi

  echo ""
  for i in "${!WORKTREES[@]}"; do
    echo -e "  ${ORANGE}${BOLD}вңҰ worktree $((i+1)) / ${SPLITS}${NC}  ${DIM}$(basename "${WORKTREES[$i]}")${NC}"
  done
  echo ""
  echo -e "  ${ORANGE}${BOLD}opening ${SPLITS} tmux panesвҖҰ${NC}"
  echo ""

  if [[ -n "${TMUX:-}" ]]; then
    tmux new-window -c "${WORKTREES[0]}" -n "$GOAL_SLUG"
    tmux send-keys "pi" Enter

    for i in $(seq 1 $((SPLITS - 1))); do
      tmux split-window -c "${WORKTREES[$i]}"
      tmux send-keys "pi" Enter
      tmux select-layout "$LAYOUT"
    done

    tmux select-pane -t 0
  else
    tmux new-session -d -s "$SESSION" -c "${WORKTREES[0]}"
    tmux send-keys -t "$SESSION" "pi" Enter

    for i in $(seq 1 $((SPLITS - 1))); do
      tmux split-window -t "$SESSION" -c "${WORKTREES[$i]}"
      tmux send-keys -t "$SESSION" "pi" Enter
      tmux select-layout -t "$SESSION" "$LAYOUT"
    done

    tmux select-pane -t "$SESSION:0.0"
    tmux attach-session -t "$SESSION"
  fi
fi
