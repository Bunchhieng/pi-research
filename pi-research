#!/usr/bin/env bash
set -euo pipefail

# pi-research вҖ” launch pi in a fresh git worktree, or clean up old ones
#
# Usage:
#   pi-research [goal]              Single worktree, launches pi
#   pi-research -s N [goal]         N worktrees in tmux splits
#   pi-research status              Dashboard of all active research sessions
#   pi-research attach [slug]       Re-attach to a running tmux session
#   pi-research cleanup             Interactive cleanup of merged worktrees
#   pi-research cleanup --all       Remove all merged worktrees without prompt
#   pi-research cleanup <slug>      Remove a specific worktree by name match

# ---------------------------------------------------------------------------
# Colors
# ---------------------------------------------------------------------------

ORANGE='\033[38;5;214m'
AMBER='\033[38;5;208m'
BROWN='\033[38;5;172m'
CREAM='\033[38;5;230m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${GREEN}$1${NC}"; }
warn()  { echo -e "${YELLOW}вҡ  $1${NC}"; }
fail()  { echo -e "${RED}ERROR: $1${NC}" >&2; exit 1; }

cpu_count() { sysctl -n hw.logicalcpu 2>/dev/null || nproc 2>/dev/null || echo 4; }

# ---------------------------------------------------------------------------
# Pre-warm pool вҖ” keeps 2 ready worktrees so startup is near-instant
# ---------------------------------------------------------------------------

pool_dir()  { echo "$HOME/.pi-research-pool/${REPO_NAME}"; }

pool_prune() {
  local pdir="$1" base_commit="$2"
  [[ -d "$pdir" ]] || return 0
  for entry in "$pdir"/*/; do
    [[ -d "$entry" ]] || continue
    local stored wt_path branch
    stored=$(cat "${entry}base"   2>/dev/null || true)
    wt_path=$(cat "${entry}path"  2>/dev/null || true)
    branch=$(cat "${entry}branch" 2>/dev/null || true)
    if [[ "$stored" != "$base_commit" || -z "$wt_path" || ! -d "$wt_path" ]]; then
      [[ -n "$wt_path" ]] && git -C "$REPO_ROOT" worktree remove --force "$wt_path" 2>/dev/null || true
      [[ -n "$branch"  ]] && git -C "$REPO_ROOT" branch -D "$branch" 2>/dev/null || true
      rm -rf "$entry"
    fi
  done
}

# Claim one pool entry: rename its branch + move worktree to target location.
# Returns 0 on success, 1 if nothing usable in pool.
pool_claim() {
  local pdir="$1" target_dir="$2" target_branch="$3" base_commit="$4"
  [[ -d "$pdir" ]] || return 1
  for entry in "$pdir"/*/; do
    [[ -d "$entry" ]] || continue
    local stored pool_branch pool_path
    stored=$(cat "${entry}base"   2>/dev/null || true)
    pool_branch=$(cat "${entry}branch" 2>/dev/null || true)
    pool_path=$(cat "${entry}path" 2>/dev/null || true)
    [[ "$stored" == "$base_commit" && -n "$pool_branch" && -d "$pool_path" ]] || continue
    git -C "$REPO_ROOT" branch -m "$pool_branch" "$target_branch" 2>/dev/null || continue
    if git -C "$REPO_ROOT" worktree move "$pool_path" "$target_dir" 2>/dev/null; then
      rm -rf "$entry"
      return 0
    fi
    git -C "$REPO_ROOT" branch -m "$target_branch" "$pool_branch" 2>/dev/null || true
  done
  return 1
}

pool_create_one() {
  local pdir="$1" base_commit="$2"
  mkdir -p "$pdir"
  local ts entry pool_branch wt_path
  ts="$(date +%Y%m%d-%H%M%S)-$$-${RANDOM}"
  entry="${pdir}/${ts}"
  pool_branch="autoresearch/pool-${ts}"
  wt_path="${entry}/worktree"
  mkdir -p "$entry"
  git -C "$REPO_ROOT" -c checkout.workers="$(cpu_count)" \
    worktree add "$wt_path" -b "$pool_branch" "$BASE_BRANCH" >"${entry}/log" 2>&1 \
  && {
    printf '%s' "$base_commit"  > "${entry}/base"
    printf '%s' "$pool_branch"  > "${entry}/branch"
    printf '%s' "$wt_path"      > "${entry}/path"
    rm -f "${entry}/log"
  } || {
    git -C "$REPO_ROOT" worktree remove --force "$wt_path" 2>/dev/null || true
    git -C "$REPO_ROOT" branch -D "$pool_branch" 2>/dev/null || true
    git -C "$REPO_ROOT" worktree prune 2>/dev/null || true
    rm -rf "$entry"
  }
}

# Silently refill pool to 2 warm entries (called in background after each launch)
pool_replenish() {
  local pdir base_commit count needed
  pdir=$(pool_dir)
  base_commit=$(git -C "$REPO_ROOT" rev-parse "$BASE_BRANCH" 2>/dev/null) || return 0
  count=0
  if [[ -d "$pdir" ]]; then
    for entry in "$pdir"/*/; do
      [[ -f "${entry}base" ]] || continue
      local stored wt_path
      stored=$(cat "${entry}base" 2>/dev/null || true)
      wt_path=$(cat "${entry}path" 2>/dev/null || true)
      [[ "$stored" == "$base_commit" && -d "$wt_path" ]] && count=$(( count + 1 )) || true
    done
  fi
  needed=$(( 2 - count ))
  for _ in $(seq 1 "$needed"); do
    pool_create_one "$pdir" "$base_commit" &
  done
  wait
}

